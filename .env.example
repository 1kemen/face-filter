# ============================================================
# 어레인지 클리닉 대시보드 - 환경변수 설정 예시
# 이 파일을 복사해서 .env 파일로 사용하세요: cp .env.example .env
# Vercel 배포 시: 대시보드 Settings > Environment Variables에 등록
# ============================================================

# [필수] OpenAI API Key
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-...

# [선택] OpenAI 모델 (기본값: gpt-4o-mini)
# 파인튜닝 모델 사용 시: ft:gpt-4o-mini-xxxxx
# OPENAI_MODEL=gpt-4o-mini

# [선택] Google Sheets 채팅 로그 웹훅 URL
# Google Apps Script 웹앱 배포 후 발급되는 URL
# 없으면 페필이 동작은 정상, 로그 기록만 안 됨
# SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
